    def prepare_features(self, df):
        """
        Prepare features for modeling with pipeline
        """
        # Define feature types
        categorical_features = ['gender', 'primary_condition', 'insurance', 
                               'age_group', 'bmi_category']
        numerical_features = ['age', 'bmi', 'length_of_stay', 'num_comorbidities',
                             'num_medications', 'previous_admissions', 'hemoglobin',
                             'creatinine', 'glucose', 'blood_pressure']
        binary_features = ['hypertension', 'anemia', 'renal_impairment', 'hyperglycemia', 'rural']
        
        # Create preprocessing pipeline
        preprocessor = ColumnTransformer(
            transformers=[
                ('num', StandardScaler(), numerical_features),
                ('cat', OneHotEncoder(drop='first', sparse_output=False), categorical_features),
                ('binary', 'passthrough', binary_features)
            ])
        
        # Prepare features
        X = df[categorical_features + numerical_features + binary_features]
        y = df['readmitted'].astype(int)
        
        # Store feature names
        self.feature_names = categorical_features + numerical_features + binary_features
        
        return X, y, preprocessor
    
