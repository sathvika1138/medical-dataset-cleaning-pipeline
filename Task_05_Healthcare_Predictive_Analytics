    def generate_readmission_data(self, n_patients=2000):
        """
        Generate synthetic healthcare data for readmission prediction
        """
        np.random.seed(42)
        
        # Define clinical conditions and their readmission risk
        conditions = {
            'Diabetes': {'base_risk': 0.25, 'symptoms': ['hyperglycemia', 'polyuria', 'fatigue']},
            'Heart Failure': {'base_risk': 0.35, 'symptoms': ['dyspnea', 'edema', 'fatigue']},
            'COPD': {'base_risk': 0.30, 'symptoms': ['cough', 'dyspnea', 'wheezing']},
            'Pneumonia': {'base_risk': 0.20, 'symptoms': ['fever', 'cough', 'dyspnea']},
            'Stroke': {'base_risk': 0.28, 'symptoms': ['weakness', 'speech_difficulty', 'numbness']},
            'Sepsis': {'base_risk': 0.40, 'symptoms': ['fever', 'tachycardia', 'hypotension']}
        }
        
        medications = ['Metformin', 'Lisinopril', 'Atorvastatin', 'Warfarin', 
                      'Metoprolol', 'Aspirin', 'Ibuprofen', 'Omeprazole', 
                      'Levothyroxine', 'Amoxicillin']
        
        data = []
        
        for patient_id in range(n_patients):
            # Patient demographics
            age = np.random.randint(18, 95)
            gender = np.random.choice(['M', 'F'], p=[0.48, 0.52])
            
            # BMI with realistic distribution
            bmi = np.random.normal(28, 6)
            bmi = np.clip(bmi, 15, 50)
            
            # Primary condition
            condition = np.random.choice(list(conditions.keys()))
            base_risk = conditions[condition]['base_risk']
            
            # Comorbidities
            num_comorbidities = np.random.poisson(1.2)
            comorbidities = np.random.choice(
                ['Diabetes', 'Hypertension', 'CHF', 'COPD', 'CKD', 'Anemia'],
                size=min(num_comorbidities, 3),
                replace=False
            ).tolist()
            
            # Length of stay (days)
            los = np.random.exponential(5) + 2
            los = min(int(los), 30)
            
            # Number of medications
            num_meds = np.random.randint(0, 6)
            patient_meds = np.random.choice(medications, num_meds, replace=False).tolist()
            
            # Previous admissions in last 3 years
            prev_admissions = np.random.poisson(0.8)
            
            # Lab values (simulated)
            hemoglobin = np.random.normal(13, 2)
            creatinine = np.random.normal(1.0, 0.3)
            glucose = np.random.normal(120, 40)
            blood_pressure = np.random.normal(130, 15)
            
            # Social determinants
            insurance = np.random.choice(['Private', 'Medicare', 'Medicaid', 'Uninsured'], 
                                        p=[0.4, 0.3, 0.2, 0.1])
            income_quartile = np.random.randint(1, 5)
            rural = np.random.choice([0, 1], p=[0.8, 0.2])
            
            # Calculate readmission risk factors
            # Base risk from condition
            risk_score = base_risk
            
            # Adjust for age
            if age > 65:
                risk_score += 0.1
            if age > 80:
                risk_score += 0.1
            
            # Comorbidity adjustment
            risk_score += len(comorbidities) * 0.05
            
            # Length of stay (longer stay = higher readmission risk)
            if los > 7:
                risk_score += 0.08
            if los > 14:
                risk_score += 0.08
            
            # Medication count
            risk_score += len(patient_meds) * 0.02
            
            # Previous admissions
            risk_score += prev_admissions * 0.05
            
            # Lab anomalies
            if hemoglobin < 10:
                risk_score += 0.05
            if creatinine > 1.5:
                risk_score += 0.05
            if glucose > 180:
                risk_score += 0.05
            if blood_pressure > 140:
                risk_score += 0.03
            
            # Social factors
            if insurance == 'Uninsured':
                risk_score += 0.1
            if income_quartile == 1:
                risk_score += 0.05
            if rural == 1:
                risk_score += 0.03
            
            # Generate readmission outcome
            readmission_prob = np.clip(risk_score, 0.05, 0.85)
            readmitted = np.random.random() < readmission_prob
            
            # Time to readmission (if readmitted)
            if readmitted:
                days_to_readmit = np.random.exponential(30) + 1
                days_to_readmit = min(int(days_to_readmit), 180)
            else:
                days_to_readmit = 0
            
            record = {
                'patient_id': f'P{patient_id:04d}',
                'age': age,
                'gender': gender,
                'bmi': round(bmi, 1),
                'primary_condition': condition,
                'comorbidities': ','.join(comorbidities),
                'num_comorbidities': len(comorbidities),
                'length_of_stay': los,
                'medications': ','.join(patient_meds),
                'num_medications': len(patient_meds),
                'previous_admissions': prev_admissions,
                'hemoglobin': round(hemoglobin, 1),
                'creatinine': round(creatinine, 2),
                'glucose': round(glucose, 0),
                'blood_pressure': round(blood_pressure, 0),
                'insurance': insurance,
                'income_quartile': income_quartile,
                'rural': rural,
                'readmitted': readmitted,
                'days_to_readmission': days_to_readmit,
                'readmission_probability': readmission_prob,
                'discharge_date': datetime.now() - timedelta(days=np.random.randint(1, 365))
            }
            data.append(record)
        
        df = pd.DataFrame(data)
        
        # Add derived features
        df['age_group'] = pd.cut(df['age'], bins=[0, 40, 60, 80, 100], 
                                labels=['<40', '40-60', '60-80', '>80'])
        df['bmi_category'] = pd.cut(df['bmi'], bins=[0, 18.5, 25, 30, 50],
                                   labels=['Underweight', 'Normal', 'Overweight', 'Obese'])
        df['hypertension'] = df['blood_pressure'] > 140
        df['anemia'] = df['hemoglobin'] < 11
        df['renal_impairment'] = df['creatinine'] > 1.5
        df['hyperglycemia'] = df['glucose'] > 150
        
        return df
    
